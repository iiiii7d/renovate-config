{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "helpers:pinGitHubActionDigestsToSemver",
    ":disableDependencyDashboard",
    "mergeConfidence:all-badges",
    ":prHourlyLimitNone",
    "customManagers:dockerfileVersions",
    "customManagers:githubActionsVersions",
    "customManagers:tsconfigNodeVersions",
    ":pinSkipCi"
  ],
  "minimumReleaseAge": "3 days",
  "minimumReleaseAgeBehaviour": "timestamp-optional",
  "packageRules": [
    {
      "matchUpdateTypes": ["pin", "digest", "pinDigest"],
      "automerge": true
    },
    {
      "matchCategories": ["ci"],
      "extends": ["schedule:daily"],
      "automerge": true
    },
    {
      "matchCategories": ["ci"],
      "matchDepNames": ["iiiii7d/cargo-msrv-workflow"],
      "minimumReleaseAge": "0 days"
    },
    {
      "matchDatasources": ["deb"],
      "defaultRegistryUrls": ["https://deb.debian.org/debian?suite=stable&components=main,contrib,non-free&binaryArch=amd64"]
    },
    {
      "matchDepNames": ["/\\brust\\b/", "/\\bRUST\\b/"],
      "matchCurrentValue": "/^nightly/",
      "schedule": ["* 0-3 * * 1"],
      "automerge": true,
      "automergeType": "branch"
    },
    {
      "matchDatasources": ["github-tags"],
      "matchPackageNames": ["rust-lang/rust"],
      "matchCurrentValue": "/^nightly/",
      "overrideDatasource": "rust-version",
      "versioning": "rust-release-channel",
      "rangeStrategy": "replace"
    },
    {
      "matchDatasources": ["rust-version"],
      "matchCurrentValue": "/^nightly/",
      "rangeStrategy": "replace"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)(workflow-templates|\\.(?:github|gitea|forgejo)/(?:workflows|actions))/.+\\.ya?ml$/",
        "/(^|/)action\\.ya?ml$/"
      ],
      "matchStrings": [
        "uses: jdx/mise-action\\b(?:\\n|.)*?with:(?:\\n|.)*?version: (?<currentValue>.+?)\\n"
      ],
      "datasourceTemplate": "github-tags",
      "packageNameTemplate": "jdx/mise"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)hk.pkl$/"
      ],
      "matchStrings": [
        "(?:amends|import) \"package://github\\.com/jdx/hk/releases/download/v(?<currentVersion>.+?)/hk@(.+?)#/.*?\\.pkl\"",
        "(?:amends|import) \"package://github\\.com/jdx/hk/releases/download/v(.+?)/hk@(?<currentVersion>.+?)#/.*?\\.pkl\""
      ],
      "datasourceTemplate": "github-tags",
      "packageNameTemplate": "jdx/hk"
    }
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true
  },
  "osvVulnerabilityAlerts": true,
  "logLevelRemap": [
    {
      "matchMessage": "/^Custom datasource/",
      "newLogLevel": "info"
    }
  ]
}
