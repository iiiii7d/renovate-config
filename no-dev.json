{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "helpers:pinGitHubActionDigestsToSemver",
    ":disableDependencyDashboard",
    "mergeConfidence:all-badges",
    ":prHourlyLimitNone",
    "customManagers:dockerfileVersions",
    "customManagers:githubActionsVersions",
    "customManagers:tsconfigNodeVersions"
  ],
  "minimumReleaseAge": "3 days",
  "minimumReleaseAgeBehaviour": "timestamp-optional",
  "packageRules": [
    {
      "matchUpdateTypes": ["pin", "digest", "pinDigest"],
      "automerge": true
    },
    {
      "matchCategories": ["ci"],
      "extends": ["schedule:daily"],
      "automerge": true
    },
    {
      "matchCategories": ["ci"],
      "matchDepNames": ["iiiii7d/cargo-msrv-workflow"],
      "minimumReleaseAge": "0 days"
    },
    {
      "matchDatasources": ["deb"],
      "registryUrls": ["https://deb.debian.org/debian?suite=stable&components=main,contrib,non-free&binaryArch=amd64"]
    },
    {
      "matchDatasources": ["rust-version"],
      "matchDepNames": ["rust-nightly"],
      "schedule": ["* 0-3 */5 * *"],
      "automerge": true,
      "automergeType": "branch"
    }, 
    {
      "matchDatasources": ["docker"],
      "matchDepNames": ["rustlang/rust"],
      "schedule": ["* 0-3 */5 * *"],
      "automerge": true,
      "automergeType": "branch"
    }
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true
  },
  "osvVulnerabilityAlerts": true,
  "logLevelRemap": [
    {
      "matchMessage": "/^Custom datasource/",
      "newLogLevel": "info"
    }
  ]
}
