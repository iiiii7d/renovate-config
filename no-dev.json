{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "helpers:pinGitHubActionDigestsToSemver",
    ":disableDependencyDashboard",
    "mergeConfidence:all-badges",
    ":prHourlyLimitNone"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^Dockerfile$/"],
      "matchStrings": [
        "ENV .*?_VERSION=\"(?<currentValue>.*?)\"\\s*#\\s*renovate:\\s*?deb\\s*?depName=(?<depName>.*?)\\s"
      ],
      "registryUrlTemplate": "https://deb.debian.org/debian?suite=stable&components=main,contrib,non-free&binaryArch=amd64",
      "datasourceTemplate": "deb"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [".github/workflows/*"],
      "matchStrings": "(?<depName>.*?)@(?<currentValue>.*?)\\s*?#\\s*?renovate:\\s*?rust-install\\s",
      "datasourceTemplate": "crate"
    }
  ],
  "packageRules": [
    {
      "matchUpdateTypes": ["pin", "digest", "pinDigest"],
      "automerge": true
    },
    {
      "matchCategories": ["ci"],
      "automerge": true
    }
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true
  }
}
