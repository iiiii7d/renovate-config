{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "helpers:pinGitHubActionDigestsToSemver",
    ":disableDependencyDashboard",
    "mergeConfidence:all-badges",
    ":prHourlyLimitNone",
    "customManagers:dockerfileVersions",
    "customManagers:githubActionsVersions",
    "customManagers:tsconfigNodeVersions"
  ],
  "minimumReleaseAge": "3 days",
  "minimumReleaseAgeBehaviour": "timestamp-optional",
  "packageRules": [
    {
      "matchUpdateTypes": ["pin", "digest", "pinDigest"],
      "automerge": true
    },
    {
      "matchCategories": ["ci"],
      "extends": ["schedule:daily"],
      "automerge": true
    },
    {
      "matchCategories": ["ci"],
      "matchDepNames": ["iiiii7d/cargo-msrv-workflow"],
      "minimumReleaseAge": "0 days"
    },
    {
      "matchDatasources": ["deb"],
      "registryUrls": ["https://deb.debian.org/debian?suite=stable&components=main,contrib,non-free&binaryArch=amd64"]
    },
    {
      "matchDatasources": ["custom.rust.nightly"],
      "extends": ["schedule:earlyMondays"],
      "automerge": true,
      "automergeType": "branch",
      "rangeStrategy": "pin"
    },
    {
      "matchDatasources": ["github-tags"],
      "matchPackageNames": ["rust-lang/rust"],
      "rangeStrategy": "pin"
    },
  ],
  "customDatasources": {
    "rust.nightly": {
      "defaultRegistryUrlTemplate": "https://raw.githubusercontent.com/rust-lang/rustup-components-history/refs/heads/gh-pages/{{packageName}}/rust.json",
      "transformTemplates": [
        "{\"releases\": [$sift(function($v, $k) {$k != 'last_available' and $v}).$each(function($v, $k) { {\"version\": 'nightly-' & $k, \"releaseTimestamp\": $k & 'T00:00Z'} })]}"
      ]
    }
  },
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true
  }
}
